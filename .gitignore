/android

# iOS — commit project but not pod cache / build artifacts (bare workflow per slice 13b)
ios/Pods/
ios/build/
ios/.xcode.env.local
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/

# dev scratch — spike results, anatomy refs, overnight agent intermediate artifacts
tmp/
